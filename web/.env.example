# ── ClaimTrust India — environment ───────────────────────────────────────────
# Copy to .env.local and fill in. All values are optional for a basic demo:
# without GEMINI_API_KEY the AI falls back to the deterministic rules engine,
# and without MONAD_PRIVATE_KEY the blockchain step returns a simulated hash.

# Google Gemini (AI reasoning). Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Monad testnet — server-side signer used by /api/record to log decisions.
# This is the agent wallet private key (testnet only — never use a mainnet key).
MONAD_PRIVATE_KEY=
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Deployed ClaimRegistry address (filled in after deployment).
NEXT_PUBLIC_CLAIM_REGISTRY_ADDRESS=
# Block explorer base used for tx / address links.
NEXT_PUBLIC_MONAD_EXPLORER=https://testnet.monadexplorer.com
